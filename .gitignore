.claude/
**/.claude/
.deploy/
.vscode/
.idea/
*.bak
*.bak.*

# ===== Fichiers d'OS =====
Thumbs.db
.DS_Store

# ===== Logs / dépendances éventuelles =====
*.log
node_modules/
vendor/

# ===== Docker / artefacts =====
*.tar
*.tar.gz
